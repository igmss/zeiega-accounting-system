# Example Environment Variables
# Copy this file to .env.local and fill in your values

# ============================================
# Supabase (replaces Firebase)
# ============================================
# Project URL — from Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://rczjehwxqjfdpcjfjhhn.supabase.co

# Anon / Public key — safe for client-side, restricted by RLS
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InJjemplaHd4cWpmZHBjamZqaGhuIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODAwNzU1NTUsImV4cCI6MjA5NTY1MTU1NX0.4ZoIBiJGq4zDcdjfCGfEnS5KT6U4jPRXRvJ_b0iPek0

# Service Role key — server-side only, bypasses RLS. NEVER expose to client
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InJjemplaHd4cWpmZHBjamZqaGhuIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc4MDA3NTU1NSwiZXhwIjoyMDk1NjUxNTU1fQ.zzAc2Mgt5VOmEsy9X9yfpxLr4jJEaPEni0-ZAZpumyc

# ============================================
# Firebase Admin SDK (deprecated — kept for backward compatibility during migration)
# ============================================
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ============================================
# NextAuth.js
# ============================================
NEXTAUTH_SECRET=your-nextauth-secret-here
NEXTAUTH_URL=http://localhost:3000

# Middleware JWT verification — can be same as NEXTAUTH_SECRET or separate for key rotation
MIDDLEWARE_SECRET=your-nextauth-secret-here

# ============================================
# Upstash Redis (rate limiting)
# ============================================
UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token-here

# ============================================
# Webhooks & Security
# ============================================
WEBHOOK_SECRET=your-shared-webhook-secret-here
CRON_SECRET=your-cron-secret-here
ALLOWED_ORIGINS=https://your-main-website.com
