# Example Environment Variables
# Copy this file to .env.local and fill in your values

# Authentication (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=your-nextauth-secret-here
NEXTAUTH_URL=http://localhost:3000

# Webhook Security
# Shared secret for authenticating webhook requests from Cloud Functions
# NOTE: The main website must send this secret via the `x-webhook-secret` HTTP header
# in all webhook requests (do not put secrets in the JSON body).
WEBHOOK_SECRET=your-shared-webhook-secret-here
# CORS: comma-separated list of allowed origins. 
# In production, must include: https://us-central1-<project-id>.cloudfunctions.net, https://your-main-website.com
ALLOWED_ORIGINS=https://your-main-website.com

# Firebase Admin SDK Configuration
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# API Rate Limiting (Upstash Redis)
# If not set, rate limiting is disabled
UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token-here

# Cron Job Security
# Must match the Bearer token in the request header
CRON_SECRET=your-cron-secret-here
# Recommended schedule: Daily (e.g., 00:00 UTC) 
# Handles: syncWebsiteOrders, processOverdueInvoices
