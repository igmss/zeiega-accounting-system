# Example Environment Variables
# Copy this file to .env.local and fill in your values

# Firebase Admin SDK — Project ID from Firebase Console > Project Settings
FIREBASE_PROJECT_ID=your-firebase-project-id

# Firebase Admin SDK — Service account client email (IAM > Service Accounts)
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com

# Firebase Admin SDK — Private key from the service account JSON key file
# Must include BEGIN/END delimiters with escaped newlines (\n)
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# NextAuth.js — Secret used to encrypt JWT tokens (generate: openssl rand -base64 32)
NEXTAUTH_SECRET=your-nextauth-secret-here

# NextAuth.js — Canonical URL of the application (e.g. https://accufinance.example.com)
NEXTAUTH_URL=http://localhost:3000

# Upstash Redis — REST URL for rate limiting (sliding-window counter)
UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io

# Upstash Redis — REST token for authenticating with the Upstash API
UPSTASH_REDIS_REST_TOKEN=your-redis-token-here

# Webhook Security — Shared secret for authenticating incoming webhook requests
# The sender must include this via the `x-webhook-secret` HTTP header
WEBHOOK_SECRET=your-shared-webhook-secret-here

# CORS — Comma-separated list of allowed origins for cross-origin requests
# In production must include Cloud Functions and main website URLs
ALLOWED_ORIGINS=https://your-main-website.com

# Cron Job Security — Bearer token for authenticating scheduled job requests
CRON_SECRET=your-cron-secret-here
# Recommended schedule: Daily (e.g., 00:00 UTC) 
# Handles: syncWebsiteOrders, processOverdueInvoices
