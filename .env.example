# Example Environment Variables
# Copy this file to .env.local and fill in your values

# ============================================
# Supabase (replaces Firebase)
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================
# Firebase Admin SDK (deprecated — kept for backward compatibility during migration)
# ============================================
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ============================================
# NextAuth.js
# ============================================
NEXTAUTH_SECRET=your-nextauth-secret-here
NEXTAUTH_URL=http://localhost:3000

# Middleware JWT verification
MIDDLEWARE_SECRET=your-nextauth-secret-here

# ============================================
# Upstash Redis (rate limiting)
# ============================================
UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token-here

# ============================================
# Webhooks & Security
# ============================================
WEBHOOK_SECRET=your-shared-webhook-secret-here
CRON_SECRET=your-cron-secret-here
ALLOWED_ORIGINS=https://your-main-website.com
