# Example Environment Variables
# Copy this file to .env.local and fill in your values

# ============================================
# Supabase — New Publishable/Secret API Keys (recommended)
# https://supabase.com/dashboard/project/_/settings/api
#
# New opaque format: sb_publishable_<random>_<checksum>
# Legacy JWT format:  eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
#
# Either format works — the Supabase SDK accepts both.
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_your_key_here
SUPABASE_SECRET_KEY=sb_secret_your_key_here

# Legacy env var name — supported as fallback for backward compatibility
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================
# NextAuth.js
# ============================================
NEXTAUTH_SECRET=your-nextauth-secret-here
NEXTAUTH_URL=http://localhost:3000
MIDDLEWARE_SECRET=your-nextauth-secret-here

# ============================================
# Upstash Redis (rate limiting)
# ============================================
UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token-here

# ============================================
# Webhooks & Security
# ============================================
WEBHOOK_SECRET=your-shared-webhook-secret-here
CRON_SECRET=your-cron-secret-here
ALLOWED_ORIGINS=https://your-main-website.com
